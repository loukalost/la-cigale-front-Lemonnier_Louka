# Configuration La Cigale – Brasserie Art Nouveau
# Copiez ce fichier en .env et remplacez les valeurs par vos configurations

# Application
VITE_APP_NAME=La Cigale
VITE_APP_ENVIRONMENT=development
VITE_APP_URL=http://localhost:5173

# Chatbot
VITE_CHATBOT_BOT_RESPONSE=Je note votre message. Pour une réservation, vous pouvez remplir notre formulaire ou nous joindre.
VITE_CHATBOT_MESSAGE_DELAY=900
VITE_CHATBOT_INITIAL_MESSAGE=Bonjour, je suis votre Maître d'Hôtel digital. Comment puis-je vous aider ?

# Formulaire de réservation
VITE_RESERVATION_SUCCESS_MESSAGE=✓ Demande envoyée !
VITE_RESERVATION_SUCCESS_DELAY=4000
VITE_RESERVATION_SUCCESS_COLOR=#22c55e
